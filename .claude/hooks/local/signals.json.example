{
  "_doc": [
    "signals.json.example — acceptance / correction 語彙の設定サンプル (フレーム層・tracked)。",
    "コピーして同 dir の signals.json (gitignore 済み) を作り、自分の語彙に差し替える。",
    "完全 opt-in: signals.json が無い間は検出が一切発火しない (デフォルト語彙は空)。",
    "マージ規則は leaf キー単位の**置換** — 定義したキーはデフォルトを丸ごと差し替える (削除も可能)。",
    "未定義キーはデフォルト維持。スキーマの詳細は .claude/hooks/_signals.py の docstring。",
    "自分の語彙の再導出手順 (transcript からの採掘と FP の刈り方) は docs/self-improvement-loop.md「シグナル語彙の較正」。",
    "以下は原環境 (日本語ユーザー) で transcript corpus に対して較正済みのパック — そのまま使わず、自分の話し方で出ない語は削ること。"
  ],
  "acceptance": {
    "exact": ["完了", "ありがとう", "できた"],
    "exact_ci": ["ok"]
  },
  "correction": {
    "patterns": [
      "違う",
      "ちがう",
      "ダメ",
      "だめ",
      "間違って(?:る|いる)",
      "間違い",
      "失敗してない\\?",
      "失敗じゃない\\?",
      "機能してる\\?",
      "機能してない\\?",
      "動いてない\\?",
      "埋もれてる",
      "なんで.*?の\\?",
      "どういうプロセスで",
      "どういうこと\\?",
      "私が間違って",
      "本当に\\?",
      "次から",
      "今後は",
      "再発防止",
      "自己改善",
      "分析して.*?修正",
      "でしょ\\?",
      "んでしょ\\?",
      "じゃない\\?",
      "じゃないの\\?",
      "じゃないか\\?",
      "べきじゃない",
      "だよね\\?",
      "必要無い",
      "不要でしょ",
      "手間かかる"
    ],
    "third_party_negation": [
      "がないと(?:だめ|ダメ)",
      "無いと(?:だめ|ダメ)",
      "だと(?:だめ|ダメ)",
      "じゃ(?:だめ|ダメ)"
    ],
    "acceptance_prefix": [
      "^\\s*なるほど",
      "^\\s*ありがとう",
      "^\\s*了解",
      "^\\s*わかった",
      "^\\s*わかりました",
      "^\\s*把握"
    ],
    "explicit_improvement": [
      "次から",
      "今後は",
      "再発防止",
      "自己改善",
      "分析して.*?修正"
    ]
  }
}
